{
	"$schema": "./node_modules/oxlint/configuration_schema.json",
	"plugins": ["typescript", "react", "import"],
	"env": {
		"browser": true,
		"node": true
	},
	"settings": {
		"react": {
			"version": "18.3.1"
		}
	},
	"ignorePatterns": ["node_modules", ".git", ".robo"],
	"categories": {
		"correctness": "warn"
	},
	"rules": {
		"import/no-cycle": "error"
	},
	"overrides": [
		{
			"files": ["src/app/**/*.{ts,tsx}", "vite-env.d.ts"],
			"env": {
				"browser": true,
				"node": false
			}
		},
		{
			"files": [
				"config/**/*.{js,mjs,cjs}",
				"env.d.ts",
				"src/commands/**/*.ts",
				"src/events/**/*.ts",
				"src/api/**/*.ts"
			],
			"env": {
				"browser": false,
				"node": true
			}
		}
	]
}
