{
	"name": "livechat",
	"version": "1.0.0",
	"private": true,
	"description": "",
	"keywords": [
		"api",
		"http",
		"server",
		"typescript",
		"web"
	],
	"type": "module",
	"scripts": {
		"build": "pnpm run build:server",
		"build:server": "tsc -p tsconfig.build.json",
		"dev": "tsx watch src/index.ts",
		"fmt": "oxfmt",
		"fmt:check": "oxfmt --check",
		"lint": "oxlint .",
		"lint:fix": "oxlint . --fix",
		"lint:style": "oxfmt",
		"prepare": "lefthook install",
		"start": "node dist/src/index.js",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@hono/node-server": "^2.0.6",
		"discord.js": "^14.26.4",
		"hono": "^4.12.27",
		"varlock": "^1.9.0",
		"ws": "^8.21.0"
	},
	"devDependencies": {
		"@flydotio/dockerfile": "^0.7.10",
		"@types/node": "^26.0.1",
		"@types/ws": "^8.18.1",
		"lefthook": "^2.1.9",
		"oxfmt": "^0.57.0",
		"oxlint": "^1.72.0",
		"tsx": "^4.22.4",
		"typescript": "^5.9.3"
	}
}
